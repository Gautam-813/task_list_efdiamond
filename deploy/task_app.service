[Unit]
Description=Shared Task Management App
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/task_app
EnvironmentFile=/opt/task_app/.env
ExecStart=/opt/task_app/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
