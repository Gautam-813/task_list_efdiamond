# Shared Task Management App — Environment Configuration
# Copy this file to .env and adjust for your deployment.

# --- Application ---
ENVIRONMENT=development
# Set to "production" to enable secure cookies and other production settings

# --- Database ---
# SQLite (default for local dev):
# DATABASE_URL=sqlite:///./task_app.db
# PostgreSQL (recommended for production):
DATABASE_URL=postgresql://user:password@localhost:5432/task_app

# --- Security ---
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-key

# Default admin credentials (used on first run)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-this-admin-password

# --- Uploads ---
MAX_UPLOAD_SIZE_MB=10

# --- Login Rate Limiting ---
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
